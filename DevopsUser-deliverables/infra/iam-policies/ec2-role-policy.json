{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AppBucketAccessOnly",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::backup0123",
        "arn:aws:s3:::backup0123/*"
      ]
    }
  ]
}