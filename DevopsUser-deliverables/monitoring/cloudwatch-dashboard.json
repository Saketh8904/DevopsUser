{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "EC2 CPU Utilization",
        "metrics": [
          [
            "AWS/EC2",
            "CPUUtilization",
            "InstanceId",
            "i-xxxxxxxxxxxxxxxxx"
          ]
        ],
        "period": 300,
        "stat": "Average",
        "region": "ap-south-1",
        "view": "timeSeries"
      }
    },
